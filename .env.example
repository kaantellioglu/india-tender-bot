# Bu dosyayi .env olarak kopyalayip kendi bilgilerinizi girin (lokal test icin).
# GitHub Actions'ta bunlar yerine repo "Settings > Secrets and variables > Actions"
# altinda ayni isimlerle secret olarak tanimlanir.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=app_password_buraya
NOTIFY_EMAIL_TO=kaan@eska.com.tr

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
